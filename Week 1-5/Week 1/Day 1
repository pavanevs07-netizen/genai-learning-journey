      "source": [
        "def business_card(Name,Company,Role):\n",
        "  print(f\"My name is {Name}, i am currently working in {Company} and my role is {Role}\")\n",
        "\n",
        "people = [{\"Name\":\"Pavan\",\"Company\":\"ACN\",\"Role\":\"SM\"},\n",
        "          {\"Name\":\"Sri\",\"Company\":\"IBM\",\"Role\":\"VE\"},\n",
        "          ]\n",
        "\n",
        "for person in people:\n",
        "  business_card(person[\"Name\"],person[\"Company\"],person[\"Role\"])\n",
        "\n",
        "\n",
        "\n"
