        "## Day 4: Extend Lead Qualifier: create a list of 5 fake leads as dicts. Loop through, qualify each automatically, print a summary table.\n",
        "\n",
        "## Day 3: Build Lead Qualifier Part 1: ask 3 yes/no questions (budget confirmed? decision maker? timeline under 90 days?) → print Hot / Warm / Cold Lead. Your first presales AI tool."
      ],
      "metadata": {
        "id": "Vlpb_36co5Aw"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "leads = [\n",
        "    {\"name\": \"Acme Corp\",       \"budget\": \"Yes\", \"decision_maker\": \"Yes\", \"timeline\": \"Yes\"},\n",
        "    {\"name\": \"BlueSky Ltd\",     \"budget\": \"Yes\", \"decision_maker\": \"Yes\", \"timeline\": \"No\"},\n",
        "    {\"name\": \"Nova Tech\",       \"budget\": \"No\",  \"decision_maker\": \"Yes\", \"timeline\": \"Yes\"},\n",
        "    {\"name\": \"Peak Solutions\",  \"budget\": \"Yes\", \"decision_maker\": \"No\",  \"timeline\": \"No\"},\n",
        "    {\"name\": \"Orbit Systems\",   \"budget\": \"No\",  \"decision_maker\": \"No\",  \"timeline\": \"No\"},\n",
        "]\n",
        "\n",
        "def qualify_lead(lead):\n",
        "  a = lead[\"budget\"]\n",
        "  b = lead[\"decision_maker\"]\n",
        "  c = lead[\"timeline\"]\n",
        "\n",
        "  if a == \"Yes\" and b == \"Yes\" and c == \"Yes\":\n",
        "    return \"Hot Lead\"\n",
        "\n",
        "  elif a == \"Yes\" and b == \"Yes\" and c == \"No\":\n",
        "    return \"Warm Lead\"\n",
        "\n",
        "  elif a == \"Yes\" and b == \"No\" and c == \"Yes\":\n",
        "    return \"Warm Lead\"\n",
        "\n",
        "  elif a == \"Yes\" and b == \"No\" and c == \"No\":\n",
        "    return \"Going out Lead\"\n",
        "\n",
        "  else :\n",
        "    return \"Cold Lead\"\n",
        "\n",
        "for lead in leads:\n",
        "  lead_name = lead[\"name\"]\n",
        "  lead_status = qualify_lead(lead)\n",
        "  print (f\"{lead_name} is a {lead_status}\")\n",
        "  print (\"\")\n",
        "\n"
      ],
