        "# Read the file\n",
        "with open(f'{base}/sprinklr_cases.txt', 'r') as f:\n",
        "    lines = f.readlines()\n",
        "\n",
        "clean_lines = [line.strip() for line in lines if line.strip()]  # remove blank lines\n",
        "\n",
        "# Analysis\n",
        "total = len(clean_lines)\n",
        "refund_lines = [l for l in clean_lines if \"refund\" in l.lower()]\n",
        "\n",
        "def count_keyword(lines, *keywords):\n",
        "    return sum(1 for l in lines if any(kw in l.lower() for kw in keywords))\n",
        "\n",
        "categories = {\n",
        "    \"Refund / billing\"    : count_keyword(clean_lines, \"refund\", \"charged\", \"billing\"),\n",
        "    \"Delivery / shipping\" : count_keyword(clean_lines, \"deliver\", \"shipping\", \"tracking\", \"late\"),\n",
        "    \"Product issues\"      : count_keyword(clean_lines, \"wrong\", \"damaged\", \"quality\", \"broken\"),\n",
        "    \"Support issues\"      : count_keyword(clean_lines, \"support\", \"agent\", \"respond\", \"ignored\"),\n",
        "}\n",
        "\n",
        "# Build summary\n",
        "summary = [\n",
        "    \"SPRINKLR CASES SUMMARY REPORT\",\n",
        "    \"=\" * 35,\n",
        "    f\"Total cases      : {total}\",\n",
        "    f\"Refund-related   : {len(refund_lines)}\",\n",
        "    f\"Other issues     : {total - len(refund_lines)}\",\n",
        "    \"\",\n",
        "    \"REFUND CASES\",\n",
        "    \"-\" * 35,\n",
        "    *[f\"  - {l}\" for l in refund_lines],\n",
        "    \"\",\n",
        "    \"TOP ISSUE CATEGORIES\",\n",
        "    \"-\" * 35,\n",
        "    *[f\"  {k:<22}: {v}\" for k, v in categories.items()],\n",
        "]\n",
        "\n",
        "# Write summary.txt\n",
        "with open(\"summary.txt\", \"w\") as f:\n",
        "    f.write(\"\\n\".join(summary))\n",
        "\n",
        "print(\"✅ summary.txt written\")\n",
        "print(\"\\n\".join(summary))"
      ],
