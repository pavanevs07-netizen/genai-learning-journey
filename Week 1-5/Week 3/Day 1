      "source": [
        "import requests #after the requests package is installed, we import the requests library within the session\n",
        "import json #this is to call the json package. this has commands to parse the json and store it as a dict\n",
        "\n",
        "url = \"https://api.exchangerate.host/latest\"  #this is needed to pass the url to be accessed to an URL object\n",
        "params = {\"base\":\"EUR\"}   #this is to create a dict called params and create a key:value pair within\n",
        "\n",
        "try:            #this is the block to run where api get call is made, response captured and stoed in data object\n",
        "  response = requests.get(url,params=params,timeout=10) #this is used to make the get api call. requests.get will club url & params with timeout set at 10s\n",
        "  response.raise_for_status() #this is to raise status error for 4xx or 5xx\n",
        "  data = response.json()  #this is to capture n push the response json to object called data\n",
        "  print(\"API call successful\")\n",
        "  print(f\"Status code:{response.status_code}\")\n",
        "\n",
        "except requests.exceptions.ConnectionError: #to catch the connection error, this code block will run\n",
        "  print(\"No internet\")\n",
        "  data = None\n",
        "\n",
        "except requests.exceptions.Timeout:         #to catch the timeout error, this code block will run\n",
        "  print(\"Timeout error\")\n",
        "  data = None\n",
        "\n",
        "except requests.exceptions.HttpError as e:      #to catch the Http error, this code block will run\n",
        "  print(f\"Http error: {e}\")\n",
        "  data = None\n",
        "\n",
        "except requests.exceptions.RequestException as e:    #to catch any other unexpected error, this code block will run\n",
        "  print(f\"unexpected error: {e}\")\n",
        "  data = None\n",
        "\n",
        "\n",
        "# Step 4: Parse JSON and print clean table\n",
        "if data:\n",
        "    # Safely get the 'rates' dictionary. If not present, default to an empty dict.\n",
        "    exchange_rates = data.get(\"rates\", {})\n",
        "    target_currencies = [\"USD\", \"GBP\", \"CHF\", \"NOK\", \"SEK\"]\n",
        "\n",
        "    print(f\"\\n{'='*35}\")\n",
        "    print(f\"  Exchange Rates — Base: EUR\")\n",
        "    print(f\"  Date: {data.get('date', 'N/A')}\")\n",
        "    print(f\"{'='*35}\")\n",
        "    print(f\"  {'Currency':<12} {'Rate':>10}\")\n",
        "    print(f\"  {'-'*22}\")\n",
        "\n",
        "    for currency in target_currencies:\n",
        "        # Use the corrected variable name 'exchange_rates'\n",
        "        rate = exchange_rates.get(currency, \"N/A\")\n",
        "        if rate != \"N/A\":\n",
        "            print(f\"  {currency:<12} {rate:>10.4f}\")\n",
        "        else:\n",
        "            print(f\"  {currency:<12} {'Not found':>10}\")\n",
        "\n",
        "    print(f\"{'='*35}\")\n",
        "\n",
        "else:\n",
        "    print(\"\\n⚠️  Skipping table — no data available\")\n",
        "    print(\"Fallback rates (hardcoded as of May 2026):\")\n",
        "    fallback = {\"USD\": 1.08, \"GBP\": 0.85, \"CHF\": 0.97, \"NOK\": 11.72, \"SEK\": 11.45}\n",
        "    for k, v in fallback.items():\n",
        "        print(f\"  {k}: {v}\")"
      ],
