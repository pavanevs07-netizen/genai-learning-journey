      "cell_type": "code",
      "source": [
        "import requests\n",
        "from datetime import datetime, timedelta      #timedelta is to get previous dates like data from 7 days back. datetime gives exact time\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import os\n",
        "\n",
        "# Calculate dates\n",
        "today = datetime.now()        #date time now\n",
        "week_ago = today - timedelta(days=7)      # previous dates 7 days ago\n",
        "\n",
        "# Format dates for API (YYYY-MM-DD)\n",
        "start_date = week_ago.strftime(\"%Y-%m-%d\")      #to convert the date format into the format api needs\n",
        "end_date = today.strftime(\"%Y-%m-%d\")\n",
        "\n",
        "# Get Paris weather for past week\n",
        "url = f\"https://api.open-meteo.com/v1/forecast?latitude=48.85&longitude=2.35&start_date={start_date}&end_date={end_date}&daily=temperature_2m_max,temperature_2m_min\"\n",
        "\n",
        "response = requests.get(url)\n",
        "data = response.json()        #this is by dfault a dict datatype object created for json\n",
        "print(data)\n",
        "\n",
        "\n",
        "print(\"\\n\")\n",
        "print(\"-\"*35)\n",
        "\n",
        "# Extract the daily data\n",
        "daily_data = data['daily']        #to fetch the values for key:daily from the dict data and store it into daily_data\n",
        "\n",
        "# Create a DataFrame              #this is a pandas function where the data extracted into the above object is neatly formatted into a table woth 3 columns - date,max_temp,min_temp\n",
        "df = pd.DataFrame({\n",
        "    'date': daily_data['time'],\n",
        "    'max_temp': daily_data['temperature_2m_max'],\n",
        "    'min_temp': daily_data['temperature_2m_min']\n",
        "})\n",
        "\n",
        "# Convert date strings to datetime\n",
        "df['date'] = pd.to_datetime(df['date'])\n",
        "\n",
        "print(df)\n",
        "\n",
        "print(\"\\n\")\n",
        "print(\"-\"*35)\n",
        "\n",
        "\n",
        "# Create the plot\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(df['date'], df['max_temp'], marker='o', label='Max Temp')\n",
        "plt.plot(df['date'], df['min_temp'], marker='o', label='Min Temp')\n",
        "\n",
        "# Add labels and title\n",
        "plt.xlabel('Date')\n",
        "plt.ylabel('Temperature (°C)')\n",
        "plt.title('Paris Weather - Past 7 Days')\n",
        "plt.legend()\n",
        "\n",
        "# Rotate x-axis labels for readability\n",
        "plt.xticks(rotation=45)\n",
        "plt.tight_layout()\n",
        "\n",
        "# Save the plot\n",
        "plt.savefig('weather_chart.png')\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n\")\n",
        "print(\"-\"*35)\n",
        "\n",
        "\n",
        "# Create data folder if it doesn't exist\n",
        "if not os.path.exists(f'{base}Week 3/data'):\n",
        "    os.makedirs(f'{base}Week 3/data')\n",
        "\n",
        "# Save to CSV\n",
        "df.to_csv(f'{base}Week 3/data/paris_weather.csv', index=False)\n",
        "print(f\"{base}Week3/data/paris_weather.csv\")"
      ],
