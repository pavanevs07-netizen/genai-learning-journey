        "# complaint_schema.py\n",
        "# Central data contract for the complaint intelligence platform\n",
        "# Every module validates against this schema\n",
        "\n",
        "import os\n",
        "import re\n",
        "import json\n",
        "import importlib.util\n",
        "from pydantic import BaseModel, Field, field_validator, model_validator\n",
        "from typing import Literal, Optional\n",
        "from uuid import UUID, uuid4\n",
        "from datetime import datetime\n",
        "\n",
        "# --- LLM Client Import ---\n",
        "# Uses importlib to load directly from file path — avoids sys.path issues with spaces in Drive path\n",
        "_llm_path = '/gdrive/My Drive/Colab Notebooks/GenAI Learning Journey/Intelligence/llm_client.py'\n",
        "_spec = importlib.util.spec_from_file_location(\"llm_client\", _llm_path)\n",
        "_llm_module = importlib.util.module_from_spec(_spec)\n",
        "_spec.loader.exec_module(_llm_module)\n",
        "LLMClient = _llm_module.LLMClient\n",
        "\n",
        "\n",
        "# ─────────────────────────────────────────────\n",
        "# SCHEMA — Central Data Contract\n",
        "# ─────────────────────────────────────────────\n",
        "\n",
        "class Complaint(BaseModel):\n",
        "\n",
        "    # --- Core Identity ---\n",
        "    id: UUID = Field(default_factory=uuid4)\n",
        "\n",
        "    # --- Complaint Content ---\n",
        "    text: str = Field(min_length=10, max_length=3000)\n",
        "\n",
        "    # --- Classification ---\n",
        "    vertical: Literal['banking', 'healthcare', 'saas', 'insurance']\n",
        "    channel: Literal['email', 'phone', 'chat', 'social', 'web']\n",
        "    category: Optional[str] = None\n",
        "    urgency: Optional[int] = Field(default=None, ge=1, le=5)\n",
        "\n",
        "    # --- Metadata ---\n",
        "    received_at: datetime = Field(default_factory=datetime.now)\n",
        "    language: str = 'en'\n",
        "    pii_redacted: bool = False\n",
        "    escalate: bool = False\n",
        "    regulatory_flags: list[str] = []\n",
        "\n",
        "\n",
        "    # --- Validator 1: Block raw IBANs in complaint text ---\n",
        "    @field_validator('text')\n",
        "    @classmethod\n",
        "    def text_must_not_contain_iban(cls, v):\n",
        "        iban_pattern = r'GB\\d{2}[A-Z]{4}\\d{14}'\n",
        "        if re.search(iban_pattern, v):\n",
        "            raise ValueError(\"Complaint text must not contain raw IBAN numbers. Redact before submission.\")\n",
        "        return v\n",
        "\n",
        "\n",
        "    # --- Validator 2: Urgency requires category ---\n",
        "    @model_validator(mode='after')\n",
        "    def urgency_requires_category(self):\n",
        "        if self.urgency is not None and self.category is None:\n",
        "            raise ValueError(\"urgency can only be set if category is also provided.\")\n",
        "        return self\n",
        "\n",
        "\n",
        "# ─────────────────────────────────────────────\n",
        "# FACTORY — Generates Synthetic Complaints via LLM\n",
        "# ─────────────────────────────────────────────\n",
        "\n",
        "def complaint_factory(n: int, vertical: str) -> list[Complaint]:\n",
        "    \"\"\"\n",
        "    Generates n synthetic realistic complaints for a given vertical.\n",
        "    Uses LLMClient from:\n",
        "    /gdrive/My Drive/Colab Notebooks/GenAI Learning Journey/Intelligence/llm_client.py\n",
        "    \"\"\"\n",
        "\n",
        "    client = LLMClient()\n",
        "\n",
        "    system_prompt = f\"Generate realistic {vertical} customer complaints in JSON format\"\n",
        "\n",
        "    user_prompt = f\"\"\"Generate {n} realistic {vertical} customer complaints.\n",
        "Return ONLY a JSON array with no explanation, no markdown, no backticks.\n",
        "Each object must have exactly these keys:\n",
        "- text (string, realistic complaint, 20-200 words)\n",
        "- channel (one of: email, phone, chat, social, web)\n",
        "- category (string, e.g. 'billing issue', 'service outage', 'claim delay')\n",
        "- urgency (integer 1-5)\n",
        "- language (default 'en')\n",
        "\n",
        "Example:\n",
        "[\n",
        "  {{\n",
        "    \"text\": \"I have been waiting 3 weeks for my insurance claim to be processed with no update.\",\n",
        "    \"channel\": \"email\",\n",
        "    \"category\": \"claim delay\",\n",
        "    \"urgency\": 4,\n",
        "    \"language\": \"en\"\n",
        "  }}\n",
        "]\"\"\"\n",
        "\n",
        "    # Call LLMClient.generate() — returns dict with 'response_text', 'tokens_used', 'cost_usd', 'latency_ms'\n",
        "    result = client.generate(\n",
        "        system_prompt=system_prompt,\n",
        "        user_message=user_prompt,\n",
        "        temperature=0.7,      # higher temp = more varied synthetic complaints\n",
        "        max_tokens=1000       # n complaints need more tokens than a single classification\n",
        "    )\n",
        "\n",
        "    # Extract the actual text from the response dict\n",
        "    raw = result[\"response_text\"]\n",
        "\n",
        "    # Strip any accidental markdown fences the LLM might add\n",
        "    clean = raw.strip().replace(\"```json\", \"\").replace(\"```\", \"\").strip()\n",
        "\n",
        "    # Parse JSON response\n",
        "    complaints_data = json.loads(clean)\n",
        "\n",
        "    # Build and validate Complaint objects\n",
        "    complaints = []\n",
        "    for item in complaints_data:\n",
        "        complaint = Complaint(\n",
        "            text=item['text'],\n",
        "            vertical=vertical,\n",
        "            channel=item['channel'],\n",
        "            category=item.get('category'),\n",
        "            urgency=item.get('urgency'),\n",
        "            language=item.get('language', 'en')\n",
        "        )\n",
        "        complaints.append(complaint)\n",
        "\n",
        "    return complaints\n",
        "\n",
        "\n",
        "# ─────────────────────────────────────────────\n",
        "# QUICK TEST BLOCK\n",
        "# ─────────────────────────────────────────────\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "\n",
        "    # Test 1: Valid complaint\n",
