        "        vertical=\"insurance\",\n",
        "        channel=\"email\",\n",
        "        category=\"claim delay\",\n",
        "        urgency=4\n",
        "    )\n",
        "    print(\"✅ Valid complaint created:\", c1.id)\n",
        "\n",
        "    # Test 2: IBAN in text — should raise error\n",
        "    try:\n",
        "        c2 = Complaint(\n",
        "            text=\"My account GB94BARC10201530093459 was debited incorrectly.\",\n",
        "            vertical=\"banking\",\n",
        "            channel=\"chat\"\n",
        "        )\n",
        "    except Exception as e:\n",
        "        print(\"🚫 IBAN validator caught:\", e)\n",
        "\n",
        "    # Test 3: Urgency without category — should raise error\n",
        "    try:\n",
        "        c3 = Complaint(\n",
        "            text=\"The app keeps crashing every time I try to login.\",\n",
        "            vertical=\"saas\",\n",
        "            channel=\"web\",\n",
        "            urgency=5\n",
        "        )\n",
        "    except Exception as e:\n",
        "        print(\"🚫 Urgency validator caught:\", e)\n",
        "\n",
        "    # Test 4: Factory via LLM\n",
        "    print(\"\\n⏳ Generating complaints via LLM...\")\n",
        "    batch = complaint_factory(n=3, vertical=\"healthcare\")\n",
        "    print(f\"✅ Factory generated {len(batch)} complaints:\")\n",
        "    for c in batch:\n",
        "        print(f\"  - [{c.vertical}] [{c.channel}] urgency={c.urgency} | {c.text[:60]}...\")"
