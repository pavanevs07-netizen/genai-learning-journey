        "print(\"PRESIDIO PII ANONYMISATION — 10 SYNTHETIC COMPLAINTS\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "for i, text in enumerate(complaints, 1):\n",
        "    print(f\"\\n{'─'*70}\")\n",
