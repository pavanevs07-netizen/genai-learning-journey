        "\n",
        "    # STEP A: ANALYZE\n",
        "    # analyzer.analyze() runs the full NLP + recognizer pipeline\n",
        "    # Returns: List[RecognizerResult]\n",
        "    # Each RecognizerResult = {entity_type, start, end, score, recognition_metadata}\n",
        "    results = analyzer.analyze(\n",
        "        text=text,\n",
        "        entities=ENTITIES,\n",
        "        language=\"en\"\n",
        "    )\n",
        "    # 'language' param selects which NLP model to use\n",
        "    # All results have character-level positions (not word-level)\n",
        "    # This is important: \"james.thornton@gmail.com\" → start=52, end=76\n",
        "\n",
        "    # STEP B: ANONYMIZE\n",
        "    # anonymizer.anonymize() takes original text + result spans\n",
        "    # Applies operators in reverse order (end→start) to preserve positions\n",
        "    # This is why overlapping spans don't corrupt the output\n",
        "    anonymized = anonymizer.anonymize(\n",
        "        text=text,\n",
        "        analyzer_results=results,\n",
        "        operators=operators\n",
        "    )\n",
        "    # anonymized.text = the redacted string\n",
        "    # anonymized.items = list of what was replaced and where\n",
        "\n",
