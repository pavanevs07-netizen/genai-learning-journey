        "# ── OPERATOR MAP ─────────────────────────────────────────────\n",
        "# Defines what happens to each detected entity type\n",
        "# \"replace\" swaps the span with a fixed string\n",
        "# Other options: \"hash\", \"mask\", \"encrypt\", \"redact\" (empty string)\n",
        "\n",
        "operators = {\n",
        "    \"PERSON\":        OperatorConfig(\"replace\", {\"new_value\": \"[PERSON]\"}),\n",
        "    \"IBAN_CODE\":     OperatorConfig(\"replace\", {\"new_value\": \"[IBAN_REDACTED]\"}),\n",
        "    \"EMAIL_ADDRESS\": OperatorConfig(\"replace\", {\"new_value\": \"[EMAIL_REDACTED]\"}),\n",
        "    \"PHONE_NUMBER\":  OperatorConfig(\"replace\", {\"new_value\": \"[PHONE_REDACTED]\"}),\n",
        "    \"UK_NHS\":        OperatorConfig(\"replace\", {\"new_value\": \"[NHS_REDACTED]\"}),\n",
        "    \"NRP\":           OperatorConfig(\"replace\", {\"new_value\": \"[NATIONAL_ID_REDACTED]\"}),\n",
        "    \"DEFAULT\":       OperatorConfig(\"replace\", {\"new_value\": \"[REDACTED]\"}),\n",
        "}\n",
        "# NRP = \"Nationally Registered Person\" — Presidio's label for\n",
        "# national ID numbers including UK National Insurance (AB 12 34 56 C)\n",
        "# DEFAULT catches any entity type not explicitly listed above"
