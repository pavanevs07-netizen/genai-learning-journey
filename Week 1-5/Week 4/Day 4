        "    \"IBAN_CODE\",      # Pattern-based + MOD-97 checksum\n",
        "    \"EMAIL_ADDRESS\",  # Pattern-based (RFC 5321 compliant regex)\n",
        "    \"PHONE_NUMBER\",   # Pattern-based + context-aware (multi-country)\n",
        "    \"UK_NHS\",         # Pattern-based + modulus-11 checksum + context\n",
        "    \"NRP\",            # Pattern-based + context (national ID formats)\n",
        "]"
