        "# ── IMPORTS ──────────────────────────────────────────────────\n",
        "\n",
        "from presidio_analyzer import AnalyzerEngine\n",
        "from presidio_analyzer.nlp_engine import NlpEngineProvider\n",
        "from presidio_anonymizer import AnonymizerEngine\n",
        "from presidio_anonymizer.entities import OperatorConfig\n",
        "import re  # kept for the comparison section only"
      ],
      "metadata": {
        "id": "ILhp97Saged1"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── NLP ENGINE CONFIGURATION ─────────────────────────────────\n",
        "# We explicitly tell Presidio: use spaCy, use the large English model\n",
        "# Default would also pick en_core_web_lg but explicit config is auditable\n",
        "\n",
        "configuration = {\n",
        "    \"nlp_engine_name\": \"spacy\",\n",
        "    \"models\": [\n",
        "        {\"lang_code\": \"en\", \"model_name\": \"en_core_web_lg\"}\n",
        "    ]\n",
        "}\n",
        "# lang_code: ISO 639-1 language code\n",
        "# model_name: must match an installed spaCy model exactly\n",
        "# You can add {\"lang_code\": \"de\", \"model_name\": \"de_core_news_lg\"} for German\n",
        "# Presidio supports multi-language detection in one pipeline\n",
        "\n",
        "provider = NlpEngineProvider(nlp_configuration=configuration)\n",
        "nlp_engine = provider.create_engine()\n",
        "# This loads the spaCy model into memory — ~741MB for lg\n",
        "# In production: load once at startup, reuse across all requests"
      ],
      "metadata": {
        "id": "sEqDTna-fpHb"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ── ENGINE INITIALISATION ────────────────────────────────────\n",
        "\n",
        "analyzer = AnalyzerEngine(\n",
        "    nlp_engine=nlp_engine,\n",
        "    supported_languages=[\"en\"]\n",
        ")\n",
        "# AnalyzerEngine loads:\n",
        "# 1. Your spaCy NLP engine (for NER-based recognizers)\n",
        "# 2. All built-in pattern recognizers (IBAN, EMAIL, PHONE, NHS, etc.)\n",
        "# 3. Context enhancers for each recognizer\n",
        "# supported_languages: controls which language models can be used\n",
        "\n",
        "anonymizer = AnonymizerEngine()\n",
        "# AnonymizerEngine has no NLP dependency\n",
        "# It only needs: original text + span positions + operator rules\n",
        "# Completely stateless — can be shared across threads safely"
      ],
